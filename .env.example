ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=sqlite:///./data/kinews.db
MAX_ARTICLES_PER_FETCH=100
DEDUP_TITLE_THRESHOLD=0.85

# Newsletter / IMAP
# Standard-Host: imap.gmx.net:993 (GMX)
# Andere Anbieter: imap.gmail.com, outlook.office365.com, imap.web.de, ...
# NEWSLETTER_IMAP_HOST=imap.gmx.net
# NEWSLETTER_IMAP_PORT=993
NEWSLETTER_IMAP_USER=deine.adresse@gmx.at
NEWSLETTER_IMAP_PASSWORD=dein-passwort
NEWSLETTER_IMAP_FOLDER=Newsletter

# Microsoft Teams Webhook (Power-Automate-Workflow)
# Channel → ⋯ → Workflows → "Beim Empfang einer Webhookanforderung in einem Kanal posten"
# Die generierte HTTP-POST-URL hier eintragen, dann kann der Teams-Post aus den
# Favoriten direkt in den Channel gesendet werden. Leer = Senden deaktiviert.
TEAMS_WEBHOOK_URL=
# Headerbild des Ankündigungs-Posts. Teams lädt es server-seitig → die URL muss
# OHNE Login Bild-Bytes liefern (Test: in einem Inkognito-Fenster öffnen).
# z.B. SharePoint "Anyone with the link". Leer = Headline ohne Bild.
TEAMS_HEADER_IMAGE_URL=
